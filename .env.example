IFRE_DB_URL=postgresql+psycopg://user:pass@host:5432/dbname
# Optional: schema name (for Postgres); default is "references"
# IFRE_DB_SCHEMA=references
IFRE_AVG_SPEED_KMPH=30
IFRE_MIN_SPEED_KMPH=5
IFRE_MAX_SPEED_KMPH=120
IFRE_EDGE_WEIGHT_IN_METERS=1
IFRE_SCORE_W_DISTANCE=0.30
IFRE_SCORE_W_ETA=0.30
IFRE_SCORE_W_WAIT=0.15
IFRE_SCORE_W_LATE=0.25
# Optional: force graph to be bidirectional (true/false). If not set, auto-detects.
# IFRE_GRAPH_BIDIRECTIONAL=true
# Optional: threshold for auto-detection of bidirectional graph
# IFRE_GRAPH_BIDIRECTIONAL_THRESHOLD=0.05
# Comma-separated document codes for tasks in dcm (EAV) schema
IFRE_TASK_DOCUMENT_CODES=TRS_ORDER,TRS_BBJORDER,TRS_RTAORDER,TRS_RTAPLNORDER
# Optional mapping file for EAV fields
IFRE_EAV_MAPPING_FILE=app/data/eav_mapping.json
# Compatibility handling
IFRE_COMPATIBILITY_STRICT=false
IFRE_COMPATIBILITY_PENALTY=10.0
IFRE_USE_SNAPSHOT_BY_PLANNING_DATE=true
IFRE_ANCHOR_UNITS_AT_PLAN_START=true
IFRE_ASSIGNMENTS_GROUPING=true
